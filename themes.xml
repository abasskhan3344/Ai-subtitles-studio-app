<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AIImageStudio" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorOnPrimaryContainer">@color/primary_dark</item>
        
        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_light</item>
        <item name="colorOnSecondary">@color/text_on_secondary</item>
        <item name="colorOnSecondaryContainer">@color/secondary_dark</item>
        
        <!-- Tertiary Colors -->
        <item name="colorTertiary">@color/accent</item>
        <item name="colorTertiaryContainer">@color/accent_light</item>
        <item name="colorOnTertiary">@color/text_on_primary</item>
        <item name="colorOnTertiaryContainer">@color/accent</item>
        
        <!-- Surface Colors -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <!-- Background Colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        
        <!-- Error Colors -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/text_on_primary</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        
        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">true</item>
        
        <!-- Window Properties -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        
        <!-- Typography -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.AIImageStudio.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.AIImageStudio.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.AIImageStudio.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.AIImageStudio.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.AIImageStudio.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.AIImageStudio.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.AIImageStudio.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.AIImageStudio.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.AIImageStudio.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.AIImageStudio.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.AIImageStudio.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.AIImageStudio.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.AIImageStudio.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.AIImageStudio.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.AIImageStudio.LabelSmall</item>
        
        <!-- Shape Appearance -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.AIImageStudio.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.AIImageStudio.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.AIImageStudio.Large</item>
    </style>

    <!-- Typography Styles -->
    <style name="TextAppearance.AIImageStudio.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">57sp</item>
        <item name="android:lineHeight">64sp</item>
    </style>

    <style name="TextAppearance.AIImageStudio.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">45sp</item>
        <item name="android:lineHeight">52sp</item>
    </style>

    <style name="TextAppearance.AIImageStudio.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">36sp</item>
        <item name="android:lineHeight">44sp</item>
    </style>

    <style name="TextAppearance.AIImageStudio.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textSize">32sp</item>
        <item name="android:lineHeight">40sp</item>
    </style>

    <style name="TextAppearance.AIImageStudio.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">28sp</item>
        <item name="android:lineHeight">36sp</item>
    </style>

    <style name="TextAppearance.AIImageStudio.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">24sp</item>
        <item name="android:lineHeight">32sp</item>
    </style>

    <style name="TextAppearance.AIImageStudio.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">22sp</item>
        <item name="android:lineHeight">28sp</item>
    </style>

    <style name="TextAppearance.AIImageStudio.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight">24sp</item>
    </style>

    <style name="TextAppearance.AIImageStudio.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">20sp</item>
    </style>

    <style name="TextAppearance.AIImageStudio.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight">24sp</item>
    </style>

    <style name="TextAppearance.AIImageStudio.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">20sp</item>
    </style>

    <style name="TextAppearance.AIImageStudio.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight">16sp</item>
    </style>

    <style name="TextAppearance.AIImageStudio.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight">20sp</item>
    </style>

    <style name="TextAppearance.AIImageStudio.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight">16sp</item>
    </style>

    <style name="TextAppearance.AIImageStudio.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:textSize">11sp</item>
        <item name="android:lineHeight">16sp</item>
    </style>

    <!-- Shape Appearances -->
    <style name="ShapeAppearance.AIImageStudio.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.AIImageStudio.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.AIImageStudio.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.AIImageStudio.Button" parent="Widget.Material3.Button">
        <item name="android:textAppearance">@style/TextAppearance.AIImageStudio.LabelLarge</item>
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Widget.AIImageStudio.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAppearance">@style/TextAppearance.AIImageStudio.LabelLarge</item>
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Widget.AIImageStudio.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAppearance">@style/TextAppearance.AIImageStudio.LabelLarge</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <!-- Card Styles -->
    <style name="Widget.AIImageStudio.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- Input Styles -->
    <style name="Widget.AIImageStudio.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

</resources>
